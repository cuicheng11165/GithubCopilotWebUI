NODE_ENV=development
LOG_LEVEL=info
LOG_DIR=./data/logs
PUBLIC_APP_URL=http://localhost:3000
API_HOST=127.0.0.1
API_PORT=4000
SANDBOX_RUNNER_HOST=127.0.0.1
SANDBOX_RUNNER_PORT=4100
WORKER_CONTROL_HOST=127.0.0.1
WORKER_CONTROL_PORT=4200
# Relative SQLite paths resolve from packages/db/prisma-sqlite.
DATABASE_URL=file:../../../data/copilot.db?connection_limit=1
COOKIE_SECRET=replace-with-at-least-32-random-characters
TOKEN_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key
REPOSITORIES_CONFIG=./config/repositories.yaml
COPILOT_HOME=./data/copilot
SANDBOX_RUNNER_URL=http://127.0.0.1:4100
SANDBOX_RUNNER_TOKEN=replace-with-a-long-random-service-token
WORKER_CONTROL_URL=http://127.0.0.1:4200
WORKER_CONTROL_TOKEN=replace-with-a-different-long-random-service-token
WORKER_POLL_INTERVAL_MS=200
EVENT_POLL_INTERVAL_MS=200
# Commands and private scripts run directly as the current host user.
LOCAL_SANDBOX_TMP_ROOT=./data/local-sandbox
WORKER_CONCURRENCY=2
APPROVAL_TIMEOUT_SECONDS=300
COMMAND_TIMEOUT_SECONDS=120
COMMAND_MAX_OUTPUT_BYTES=1048576
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_ALLOWED_ORGS=your-org
GITHUB_ALLOWED_ENTERPRISES=
GHE_HOST=
GHE_CLIENT_ID=
GHE_CLIENT_SECRET=
GHE_ALLOWED_ORGS=
GHE_ALLOWED_ENTERPRISES=
