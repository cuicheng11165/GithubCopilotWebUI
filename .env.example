NODE_ENV=development
DATABASE_MODE=local
PUBLIC_APP_URL=http://localhost:3000
API_PORT=4000
SANDBOX_RUNNER_PORT=4100
# Relative SQLite paths resolve from packages/db/prisma-sqlite.
DATABASE_URL=file:../../../data/copilot.db?connection_limit=1
REDIS_URL=redis://localhost:6379
COOKIE_SECRET=replace-with-at-least-32-random-characters
TOKEN_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key
REPOSITORIES_CONFIG=./config/repositories.yaml
COPILOT_HOME=./data/copilot
SANDBOX_RUNNER_URL=http://localhost:4100
SANDBOX_RUNNER_TOKEN=replace-with-a-long-random-service-token
LOCAL_WORKER_CONCURRENCY=2
MULTI_USER_WORKER_CONCURRENCY=8
APPROVAL_TIMEOUT_SECONDS=300
COMMAND_TIMEOUT_SECONDS=120
COMMAND_MAX_OUTPUT_BYTES=1048576
SANDBOX_ALLOWED_IMAGES=copilot-web-sandbox:local
LOCAL_DATA_DIR=./data
REPOSITORIES_CONFIG_FILE=./config/repositories.yaml
REPO_ROOT=/absolute/path/to/repository
CONTAINER_RUNTIME_SOCKET=/var/run/docker.sock
POSTGRES_PASSWORD=replace-for-multi-user-mode
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_ALLOWED_ORGS=your-org
GITHUB_ALLOWED_ENTERPRISES=
GHE_HOST=
GHE_CLIENT_ID=
GHE_CLIENT_SECRET=
GHE_ALLOWED_ORGS=
GHE_ALLOWED_ENTERPRISES=
