{
  "name": "@app/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "generate": "prisma generate --schema prisma-sqlite/schema.prisma",
    "migrate": "node scripts/sqlite-prisma.mjs migrate deploy",
    "validate": "node scripts/validate.mjs",
    "prisma": "prisma"
  },
  "dependencies": {
    "@prisma/client": "6.19.0"
  },
  "devDependencies": {
    "prisma": "6.19.0"
  }
}
