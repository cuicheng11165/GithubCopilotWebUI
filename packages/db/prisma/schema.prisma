generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApprovalMode {
  INTERACTIVE
  SESSION_SCOPED
  ALLOW_ALL
}

enum SessionStatus {
  IDLE
  QUEUED
  RUNNING
  WAITING_APPROVAL
  ERROR
}

enum TurnStatus {
  QUEUED
  RUNNING
  WAITING_APPROVAL
  COMPLETED
  STOPPED
  FAILED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum PermissionStatus {
  PENDING
  APPROVED
  DENIED
  EXPIRED
}

model User {
  id              String          @id @default(uuid()) @db.Uuid
  login           String
  displayName     String?
  avatarUrl       String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  githubAccounts  GitHubAccount[]
  webSessions     WebSession[]
  chatSessions    ChatSession[]
  auditLogs       AuditLog[]

}

model GitHubAccount {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @db.Uuid
  provider              String
  providerUserId        String
  host                   String
  encryptedAccessToken  String
  encryptedRefreshToken String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  webSessions           WebSession[]
  chatSessions          ChatSession[]

  @@unique([provider, providerUserId])
  @@index([userId])
}

model WebSession {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  githubAccountId String @db.Uuid
  tokenHash  String   @unique
  csrfToken  String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  githubAccount GitHubAccount @relation(fields: [githubAccountId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([githubAccountId])
  @@index([expiresAt])
}

model ChatSession {
  id                 String              @id @default(uuid()) @db.Uuid
  sdkSessionId       String              @unique
  userId             String              @db.Uuid
  githubAccountId    String              @db.Uuid
  repositoryId       String
  repositoryName     String
  title              String              @default("New chat")
  model              String              @default("auto")
  approvalMode       ApprovalMode        @default(INTERACTIVE)
  approvalScopes     String[]
  status             SessionStatus       @default(IDLE)
  branch             String?
  headSha            String?
  dirty              Boolean             @default(false)
  skillManifest      Json?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  githubAccount      GitHubAccount        @relation(fields: [githubAccountId], references: [id], onDelete: Restrict)
  turns              Turn[]
  messages           Message[]
  events             SessionEvent[]
  permissionRequests PermissionRequest[]

  @@index([userId, updatedAt(sort: Desc)])
}

model Turn {
  id             String         @id @default(uuid()) @db.Uuid
  sessionId      String         @db.Uuid
  idempotencyKey String
  status         TurnStatus     @default(QUEUED)
  error          String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime       @default(now())
  session        ChatSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  messages       Message[]
  events         SessionEvent[]
  permissions    PermissionRequest[]

  @@unique([sessionId, idempotencyKey])
  @@index([sessionId, createdAt])
}

model Message {
  id        String      @id @default(uuid()) @db.Uuid
  sessionId String      @db.Uuid
  turnId    String?     @db.Uuid
  role      MessageRole
  content   String
  metadata  Json?
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  turn      Turn?       @relation(fields: [turnId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model SessionEvent {
  cursor    BigInt      @id @default(autoincrement())
  sessionId String      @db.Uuid
  turnId    String?     @db.Uuid
  kind      String
  data      Json
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  turn      Turn?       @relation(fields: [turnId], references: [id], onDelete: Cascade)

  @@index([sessionId, cursor])
}

model PermissionRequest {
  id          String           @id @default(uuid()) @db.Uuid
  sdkRequestId String
  sessionId   String           @db.Uuid
  turnId      String           @db.Uuid
  scope       String
  intention   String
  display     String
  payload     Json
  status      PermissionStatus @default(PENDING)
  expiresAt   DateTime
  decidedAt   DateTime?
  createdAt   DateTime         @default(now())
  session     ChatSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  turn        Turn             @relation(fields: [turnId], references: [id], onDelete: Cascade)

  @@unique([sessionId, sdkRequestId])
  @@index([sessionId, status])
}

model AuditLog {
  id        BigInt   @id @default(autoincrement())
  userId    String?  @db.Uuid
  action    String
  targetId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}
